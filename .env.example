# spritz configuration. Copy to .env and adjust; .env is gitignored.
# Only SPRITZ_ENV=prod makes the secrets below mandatory (the app refuses to
# start otherwise). In dev everything has a working default.

# dev = convenient fallbacks, warnings only. prod = security gate active,
# HTTP redirected to HTTPS + HSTS.
SPRITZ_ENV=dev

# --- Required in prod (the app will not start on the dev default) ---
# JWT signing key. Generate a long random value, e.g. `openssl rand -hex 32`.
SPRITZ_SECRET=dev-only-change-me
# Admin token for /ingest, /repo/build, /repo/import-hpkr (header X-Admin-Token).
# Unset => those endpoints stay closed (503). Generate a random value for prod.
SPRITZ_ADMIN_TOKEN=

# --- Database ---
# SQLite for dev; point at Postgres in prod (postgresql+psycopg://... , see migrations/).
SPRITZ_DB_URL=sqlite:///./spritz.db

# --- Web / networking ---
# Public URL announced in repo.info; must be reachable by HaikuDepot.
SPRITZ_PUBLIC_BASE_URL=http://localhost:8000
# Allowed CORS origins (CSV). Never "*".
SPRITZ_CORS_ORIGINS=http://localhost:8000
# Global rate limit applied by default to routes.
SPRITZ_DEFAULT_RATE_LIMIT=120/minute
# Auto-promote the first registered user to admin. Defaults ON in dev, OFF in
# prod (a stranger registering first must not own the admin routes). Force with 1/0.
# SPRITZ_BOOTSTRAP_ADMIN=

# --- Haiku host tools (optional; features degrade gracefully without them) ---
# Path to Haiku's host-built `package_repo` (see docs/SETUP-WSL.md). Without it
# the repo-proxy layer returns 503; the rest of the server still runs.
SPRITZ_PACKAGE_REPO_BIN=
# Path to Haiku's `hvif2png` for icon extraction. Without it /icon returns 404
# and the frontend falls back to a placeholder.
SPRITZ_HVIF2PNG_BIN=

# --- GitHub (ombra channel) ---
# Optional token; raises the release-API rate limit from 60 to 5000/h. Recommended in prod.
SPRITZ_GITHUB_TOKEN=

# --- Storage / caches (all gitignored) ---
# Where the repo-proxy downloads hpkg and builds catalogs.
SPRITZ_REPO_CACHE=packages-cache
# Where uploaded icons/screenshots land.
SPRITZ_UPLOAD_DIR=packages-cache/assets
# Max total bytes for the cichéto cache before pruning (default 2 GB).
SPRITZ_MAX_CACHE_BYTES=2147483648
# Above this hpkg size, spritz won't download it just to extract an icon (default 100 MB).
SPRITZ_MAX_HPKG_ICON_BYTES=104857600

# --- Catalog presentation ---
# HaikuDepotServer base URL (source of proxied/cached screenshots).
SPRITZ_HDS_URL=https://depot.haiku-os.org
# Featured cichéto id(s) on the home (CSV => carousel). Missing ids are skipped.
SPRITZ_FEATURED_CICHETO=repo.haikuports.genio
# Bàcari hidden from the showcase (CSV). Still searchable and linkable.
SPRITZ_BROWSE_HIDDEN_BACARI=haikuports
# Sub-package suffixes hidden from the showcase (CSV).
SPRITZ_BROWSE_HIDDEN_SUFFIXES=_devel,_debuginfo,_debug,_source,_sources,_doc,_docs,_dev
